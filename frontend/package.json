{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/swc-workaround.cjs",
    "dev": "next dev -p 3001",
    "prebuild": "node scripts/swc-workaround.cjs",
    "build": "next build",
    "prestart": "node scripts/swc-workaround.cjs",
    "start": "next start -p 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit --incremental false",
    "e2e": "playwright test",
    "e2e:release": "playwright test tests/e2e/employee-courses.spec.ts tests/e2e/employee-talents.spec.ts tests/e2e/employee-performance-evaluations.spec.ts tests/e2e/employee-violations.spec.ts tests/e2e/talents.spec.ts tests/e2e/academic-months.spec.ts tests/e2e/grading-policies.spec.ts tests/e2e/grading-reports.spec.ts tests/e2e/hr-reports.spec.ts",
    "qa:release": "npm run lint && npm run typecheck && npm run build && npm run e2e:release",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "14.2.28",
    "next-themes": "^0.4.6",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.28",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}