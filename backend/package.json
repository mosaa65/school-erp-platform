{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "postinstall": "node scripts/prisma-generate-safe.cjs",
    "build": "nest build",
    "prebuild": "node scripts/prisma-generate-safe.cjs",
    "postbuild": "node -e \"const fs=require('fs');if(!fs.existsSync('dist')){fs.mkdirSync('dist');}fs.writeFileSync('dist/main.js','require(\\'./src/main.js\\');');\"",
    "start": "node dist/src/main.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start:dev": "npx nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "prisma:generate": "node scripts/prisma-generate-safe.cjs",
    "prisma:migrate:dev": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=prisma/schema.prisma",
    "prisma:seed": "npm run prisma:seed:core",
    "prisma:seed:core": "ts-node prisma/seed.ts",
    "prisma:seed:demo": "ts-node prisma/seed-demo.ts",
    "prisma:seed:all": "npm run prisma:seed:core && npm run prisma:seed:demo",
    "verify:code-retirement": "node scripts/verify-code-retirement.cjs",
    "prisma:backfill:student-system-phase1": "ts-node scripts/backfill-student-system-phase1.ts",
    "migrate:monthly-grade-scores": "ts-node scripts/migrate-monthly-grade-scores.ts",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "qa:release": "npm run lint:check && npm run build && npm run test:e2e",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:finance": "jest --config ./test/jest-e2e.json --runInBand finance-journal-entries.e2e-spec.ts finance-payment-webhooks.e2e-spec.ts finance-billing-payments.e2e-spec.ts finance-bank-reconciliations.e2e-spec.ts finance-hr-integrations.e2e-spec.ts finance-procurement-integrations.e2e-spec.ts finance-transport-revenue-report.e2e-spec.ts finance-community-contributions.e2e-spec.ts finance-advanced-coverage.e2e-spec.ts"
  },
  "dependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^6.16.3",
    "@simplewebauthn/server": "^13.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/speakeasy": "^2.0.10",
    "argon2": "^0.44.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "libphonenumber-js": "^1.12.41",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "tsconfig-paths": "^4.2.0",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
