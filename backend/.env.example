NODE_ENV=production
PORT=3000

# Public URLs
# Backend base URL (Render example)
APP_BASE_URL="https://school-erp-platform.onrender.com"
# Frontend base URL
APP_WEB_URL="https://school-erp-platform.vercel.app"

# Database
DATABASE_URL="mysql://school_user:school_password@localhost:3306/school_erp_clean"

# JWT secrets (MUST be strong in production)
# IMPORTANT: Generate strong secrets before deploying. Example:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=""
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_EXPIRES_IN="15m"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
AUTH_REFRESH_COOKIE_NAME="school_erp_refresh_token"
AUTH_COOKIE_PATH="/"
# With Vercel rewrite `/backend -> BACKEND_API_URL`, the refresh cookie becomes first-party
# on the frontend domain, so `lax` is preferred (safer than `none`).
AUTH_COOKIE_SAMESITE="lax"
AUTH_COOKIE_SECURE=true

# When behind Render/Proxy/Cloudflare set to true
AUTH_TRUST_PROXY=true

# Enforce HTTPS in production
AUTH_ENFORCE_HTTPS=true

# CORS (must match frontend origin when using cookies)
CORS_ORIGIN="https://school-erp-platform.vercel.app"
CORS_CREDENTIALS=true
AUTH_DEFAULT_PHONE_REGION="YE"
AUTH_LOGIN_MAX_FAILED_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_LOCK_SECONDS=900
AUTH_CAPTCHA_AFTER_FAILED_ATTEMPTS=3
AUTH_RECAPTCHA_SECRET=""
AUTH_RECAPTCHA_MIN_SCORE=0.5
AUTH_REFRESH_RATE_LIMIT=60
AUTH_REFRESH_WINDOW_SECONDS=300
AUTH_MFA_CHALLENGE_TTL_SECONDS=300
AUTH_APPROVAL_CODE_TTL_SECONDS=600
AUTH_INITIAL_PASSWORD_TTL_HOURS=72
AUTH_TOTP_ISSUER="School ERP"
# Recommended: base64 32 bytes, or any strong string (will be SHA-256 hashed)
AUTH_TOTP_ENCRYPTION_KEY=""
AUTH_WEBAUTHN_RP_NAME="School ERP"
AUTH_WEBAUTHN_RP_ID="school-erp-platform.vercel.app"
AUTH_WEBAUTHN_ORIGINS="https://school-erp-platform.vercel.app"
AUTH_WEBAUTHN_CHALLENGE_TTL_SECONDS=300
SWAGGER_PATH="api/docs"
STRICT_EMPLOYEE_WORKFLOW=false
PAYMENT_WEBHOOK_SECRET=""
PAYMENT_WEBHOOK_IP_WHITELIST=""
FINANCE_SYSTEM_USER_ID=""
RECURRING_JOURNAL_INTERVAL_MS=900000
SEED_ADMIN_EMAIL="admin@school.local"
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PHONE_COUNTRY_CODE="+1"
SEED_ADMIN_PHONE_NATIONAL_NUMBER="5550000000"
SEED_ADMIN_FIRST_NAME="System"
SEED_ADMIN_LAST_NAME="Admin"
