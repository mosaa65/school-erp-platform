  approvedByUserId String?             @map("approved_by_user_id") @db.VarChar(191)
  approvedAt       DateTime?           @map("approved_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime?           @updatedAt @map("updated_at")

  originalInvoice StudentInvoice  @relation(fields: [originalInvoiceId], references: [id], onDelete: Restrict)
  enrollment      StudentEnrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  journalEntry    JournalEntry?    @relation("credit_debit_note_journal_entry", fields: [journalEntryId], references: [id], onDelete: SetNull)
  createdByUser   User?            @relation("credit_debit_note_created_by_user", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedByUser  User?            @relation("credit_debit_note_approved_by_user", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([originalInvoiceId], map: "idx_invoice")
  @@index([noteType], map: "idx_type")
  @@index([status], map: "idx_status")
  @@index([reason], map: "idx_reason")
  @@map("credit_debit_notes")
}

model DocumentSequence {
  id           Int         @id @default(autoincrement()) @db.UnsignedInt
  documentType DocumentType @map("document_type")
  prefix       String      @db.VarChar(10)
  fiscalYearId Int?        @map("fiscal_year_id")
  branchId     Int?        @map("branch_id")
  lastNumber   Int         @default(0) @map("last_number") @db.UnsignedInt
  numberFormat String      @default("{PREFIX}-{YEAR}-{SEQ:5}") @map("number_format") @db.VarChar(50)
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime?   @updatedAt @map("updated_at")

  fiscalYear FiscalYear? @relation(fields: [fiscalYearId], references: [id], onDelete: SetNull)
  branch     Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([documentType, fiscalYearId, branchId], map: "uk_seq")
  @@map("document_sequences")
}

model RecurringJournalTemplate {
  id               Int               @id @default(autoincrement()) @db.UnsignedInt
  templateName     String            @map("template_name") @db.VarChar(100)
  description      String?           @db.Text
  frequency        RecurringFrequency @default(MONTHLY)
  startDate        DateTime          @map("start_date") @db.Date
  endDate          DateTime?         @map("end_date") @db.Date
  nextRunDate      DateTime          @map("next_run_date") @db.Date
  branchId         Int?              @map("branch_id")
  currencyId       Int?              @map("currency_id")
  entryDescription String            @map("entry_description") @db.Text
  referenceType    String?           @map("reference_type") @db.VarChar(30)
  totalAmount      Decimal           @map("total_amount") @db.Decimal(18, 2)
  autoPost         Boolean           @default(false) @map("auto_post")
  isActive         Boolean           @default(true) @map("is_active")
  lastGeneratedAt  DateTime?         @map("last_generated_at")
  lastGeneratedJeId String?          @map("last_generated_je_id") @db.VarChar(191)
  totalGenerated   Int               @default(0) @map("total_generated") @db.UnsignedInt
  createdByUserId  String            @map("created_by_user_id") @db.VarChar(191)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime?         @updatedAt @map("updated_at")

  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  currency     Currency?    @relation(fields: [currencyId], references: [id], onDelete: SetNull)
  lastGeneratedJournalEntry JournalEntry? @relation("recurring_last_generated_je", fields: [lastGeneratedJeId], references: [id], onDelete: SetNull)
  createdByUser User        @relation("recurring_template_created_by_user", fields: [createdByUserId], references: [id], onDelete: Restrict)

  lines RecurringTemplateLine[]

  @@index([nextRunDate], map: "idx_next_run")
  @@index([isActive], map: "idx_active")
  @@index([frequency], map: "idx_frequency")
  @@map("recurring_journal_templates")
}

model RecurringTemplateLine {
  id           Int      @id @default(autoincrement()) @db.UnsignedInt
  templateId   Int      @map("template_id") @db.UnsignedInt
  lineNumber   Int      @map("line_number") @db.UnsignedSmallInt
  accountId    Int      @map("account_id")
  description  String?  @db.VarChar(255)
  debitAmount  Decimal  @default(0.00) @map("debit_amount") @db.Decimal(18, 2)
  creditAmount Decimal  @default(0.00) @map("credit_amount") @db.Decimal(18, 2)
  costCenterId Int?     @map("cost_center_id") @db.UnsignedInt

  template   RecurringJournalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  account    ChartOfAccount           @relation(fields: [accountId], references: [id], onDelete: Restrict)
  costCenter CostCenter?              @relation("recurring_template_cost_center", fields: [costCenterId], references: [id], onDelete: SetNull)

  @@unique([templateId, lineNumber], map: "uk_tpl_line")
  @@map("recurring_template_lines")
}

model CostCenter {
  id                Int      @id @default(autoincrement()) @db.UnsignedInt
  code              String   @unique @db.VarChar(20)
  nameAr            String   @map("name_ar") @db.VarChar(100)
  nameEn            String?  @map("name_en") @db.VarChar(100)
  parentId          Int?     @map("parent_id") @db.UnsignedInt
  branchId          Int?     @map("branch_id")
  managerEmployeeId String?  @map("manager_employee_id") @db.VarChar(191)
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  parent   CostCenter? @relation("cost_center_parent", fields: [parentId], references: [id], onDelete: Restrict)
  children CostCenter[] @relation("cost_center_parent")
  branch   Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  managerEmployee Employee? @relation(fields: [managerEmployeeId], references: [id], onDelete: SetNull)
  journalEntryLines      JournalEntryLine[]      @relation("journal_entry_line_cost_center")
  recurringTemplateLines RecurringTemplateLine[] @relation("recurring_template_cost_center")

  @@index([code], map: "idx_code")
  @@index([parentId], map: "idx_parent")
  @@map("cost_centers")
}
