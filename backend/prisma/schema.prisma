model Role {
  id          String    @id @default(cuid()) @db.VarChar(191)
  code        String    @unique @db.VarChar(120)
  name        String    @db.VarChar(120)
  description String?   @db.VarChar(255)
  isSystem    Boolean   @default(false) @map("is_system")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by") @db.VarChar(191)
  updatedById String?   @map("updated_by") @db.VarChar(191)

  createdBy User? @relation("role_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("role_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([deletedAt])
  @@index([isActive, deletedAt])
  @@map("roles")
}

model Permission {
  id          String    @id @default(cuid()) @db.VarChar(191)
  code        String    @unique @db.VarChar(120)
  resource    String    @db.VarChar(120)
  action      String    @db.VarChar(120)
  description String?   @db.VarChar(255)
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by") @db.VarChar(191)
  updatedById String?   @map("updated_by") @db.VarChar(191)

  createdBy User? @relation("permission_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("permission_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  rolePermissions RolePermission[]
  userPermissions UserPermission[] @relation("direct_permission_permission")

  @@index([deletedAt])
  @@index([resource, action])
  @@map("permissions")
}

model UserRole {
  id          String    @id @default(cuid()) @db.VarChar(191)
  userId      String    @map("user_id") @db.VarChar(191)
  roleId      String    @map("role_id") @db.VarChar(191)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by") @db.VarChar(191)
  updatedById String?   @map("updated_by") @db.VarChar(191)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  createdBy User? @relation("user_role_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("user_role_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([userId, roleId])
  @@index([roleId, deletedAt])
  @@index([deletedAt])
  @@map("user_roles")
}

model RolePermission {
  id           String    @id @default(cuid()) @db.VarChar(191)
  roleId       String    @map("role_id") @db.VarChar(191)
  permissionId String    @map("permission_id") @db.VarChar(191)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  createdById  String?   @map("created_by") @db.VarChar(191)
  updatedById  String?   @map("updated_by") @db.VarChar(191)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  createdBy User? @relation("role_permission_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("role_permission_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([roleId, permissionId])
  @@index([permissionId, deletedAt])
  @@index([deletedAt])
  @@map("role_permissions")
}

model UserPermission {
  id           Int       @id @default(autoincrement())
  userId       String    @map("user_id") @db.VarChar(191)
  permissionId String    @map("permission_id") @db.VarChar(191)
  validFrom    DateTime  @default(now()) @map("valid_from")
  validUntil   DateTime? @map("valid_until")
  grantReason  String    @map("grant_reason") @db.Text
  notes        String?   @db.VarChar(500)
  grantedById  String    @map("granted_by") @db.VarChar(191)
  grantedAt    DateTime  @default(now()) @map("granted_at")
  revokedAt    DateTime? @map("revoked_at")
  revokedById  String?   @map("revoked_by") @db.VarChar(191)
  revokeReason String?   @map("revoke_reason") @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  createdById  String?   @map("created_by") @db.VarChar(191)
  updatedById  String?   @map("updated_by") @db.VarChar(191)

  user       User       @relation("direct_permission_user", fields: [userId], references: [id], onDelete: Restrict)
  permission Permission @relation("direct_permission_permission", fields: [permissionId], references: [id], onDelete: Restrict)
  grantedBy  User       @relation("direct_permission_granted_by", fields: [grantedById], references: [id], onDelete: Restrict)
  revokedBy  User?      @relation("direct_permission_revoked_by", fields: [revokedById], references: [id], onDelete: SetNull)
  createdBy  User?      @relation("direct_permission_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  User?      @relation("direct_permission_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([userId, permissionId], map: "upr_user_permission_uq")
  @@index([validUntil], map: "upr_valid_until_idx")
  @@index([revokedAt], map: "upr_revoked_at_idx")
  @@index([grantedById], map: "upr_granted_by_idx")
  @@index([deletedAt], map: "upr_deleted_at_idx")
  @@map("user_permissions")
}

model UserSession {
  id           String    @id @db.VarChar(128)
  userId       String    @map("user_id") @db.VarChar(191)
  ipAddress    String?   @map("ip_address") @db.VarChar(45)
  userAgent    String?   @map("user_agent") @db.VarChar(255)
  payload      String?   @db.Text
  lastActivity DateTime  @default(now()) @map("last_activity")
  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  createdById  String?   @map("created_by") @db.VarChar(191)
  updatedById  String?   @map("updated_by") @db.VarChar(191)

  user      User  @relation("session_user", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User? @relation("session_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("session_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([userId], map: "session_user_idx")
  @@index([expiresAt], map: "session_expires_at_idx")
  @@index([deletedAt], map: "session_deleted_at_idx")
  @@map("sessions")
}

model AuditLog {
  id          String      @id @default(cuid()) @db.VarChar(191)
  actorUserId String?     @map("actor_user_id") @db.VarChar(191)
  action      String      @db.VarChar(120)
  resource    String      @db.VarChar(120)
  resourceId  String?     @map("resource_id") @db.VarChar(191)
  status      AuditStatus @default(SUCCESS)
  ipAddress   String?     @map("ip_address") @db.VarChar(64)
  userAgent   String?     @map("user_agent") @db.VarChar(255)
  details     Json?
  occurredAt  DateTime    @default(now()) @map("occurred_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")
  createdById String?     @map("created_by") @db.VarChar(191)
  updatedById String?     @map("updated_by") @db.VarChar(191)

  actorUser User? @relation("audit_actor", fields: [actorUserId], references: [id], onDelete: SetNull)
  createdBy User? @relation("audit_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("audit_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([resource, resourceId])
  @@index([actorUserId, occurredAt])
  @@index([deletedAt])
  @@map("audit_logs")
}

