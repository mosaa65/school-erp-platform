// ==========================================
// Billing & Fees Engine Models (Sprint 2)
// ==========================================

enum FeeType {
  TUITION
  TRANSPORT
  UNIFORM
  REGISTRATION
  ACTIVITY
  PENALTY
  OTHER
}

enum DiscountType {
  SIBLING
  ORPHAN
  EMPLOYEE_CHILD
  SCHOLARSHIP
  HARDSHIP
  CUSTOM
}

enum DiscountCalculationMethod {
  PERCENTAGE
  FIXED
}

enum DiscountAppliesToFeeType {
  TUITION
  TRANSPORT
  ALL
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  CANCELLED
  CREDITED
}

enum InstallmentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
