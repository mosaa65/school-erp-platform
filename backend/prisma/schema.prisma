}

enum ReminderTickerType {
  DHIKR        @map("ذكر")
  ALERT        @map("تنبيه")
  ANNOUNCEMENT @map("إعلان")
  VERSE        @map("آية")
  HADITH       @map("حديث")
}

model User {
  id           String    @id @default(cuid()) @db.VarChar(191)
