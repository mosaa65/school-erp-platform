  maxPossibleTotal    Decimal               @default(0.00) @map("max_possible_total") @db.Decimal(9, 2)
  percentage          Decimal               @default(0.00) @db.Decimal(5, 2)
  rankInClass         Int?                  @map("rank_in_class")
  rankInGrade         Int?                  @map("rank_in_grade")
  passedSubjectsCount Int                   @default(0) @map("passed_subjects_count")
  failedSubjectsCount Int                   @default(0) @map("failed_subjects_count")
  promotionDecisionId String                @map("promotion_decision_id") @db.VarChar(191)
  status              GradingWorkflowStatus @default(DRAFT)
  isLocked            Boolean               @default(false) @map("is_locked")
  lockedAt            DateTime?             @map("locked_at")
  lockedByUserId      String?               @map("locked_by_user_id") @db.VarChar(191)
  calculatedAt        DateTime?             @map("calculated_at")
  approvedByUserId    String?               @map("approved_by_user_id") @db.VarChar(191)
  approvedAt          DateTime?             @map("approved_at")
  notes               String?               @db.Text
  isActive            Boolean               @default(true) @map("is_active")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  deletedAt           DateTime?             @map("deleted_at")
  createdById         String?               @map("created_by") @db.VarChar(191)
  updatedById         String?               @map("updated_by") @db.VarChar(191)

  studentEnrollment StudentEnrollment       @relation(fields: [studentEnrollmentId], references: [id], onDelete: Restrict)
  academicYear      AcademicYear            @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  promotionDecision PromotionDecisionLookup @relation(fields: [promotionDecisionId], references: [id], onDelete: Restrict)

  lockedByUser   User? @relation("annual_result_locked_by", fields: [lockedByUserId], references: [id], onDelete: SetNull)
  approvedByUser User? @relation("annual_result_approved_by", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  createdBy      User? @relation("annual_result_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User? @relation("annual_result_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([studentEnrollmentId, academicYearId], map: "anr_enrollment_year_uq")
  @@index([academicYearId, deletedAt], map: "anr_year_del_idx")
  @@index([promotionDecisionId, deletedAt], map: "anr_decision_del_idx")
  @@index([percentage, deletedAt], map: "anr_percentage_del_idx")
  @@index([status, deletedAt], map: "anr_status_del_idx")
  @@index([isLocked, deletedAt], map: "anr_locked_del_idx")
  @@index([isActive, deletedAt], map: "anr_active_del_idx")
  @@index([deletedAt], map: "anr_deleted_at_idx")
  @@map("annual_results")
}
